{
  "id": "intro_belgica_nl",
  "audioFile": "/audio/intro_narration_nl.mp3",
  "language": "nl-BE",
  "voiceActor": "Gül Pembe Çolak",
  "totalDuration": 35.0,
  "segments": [
    {
      "id": "intro_silence",
      "type": "atmospheric",
      "start": 0.0,
      "end": 1.5,
      "description": "Wind. IJs kraakt. Het schip verschijnt in het ijs."
    },
    {
      "id": "block_1_ships",
      "type": "narration",
      "start": 1.5,
      "end": 7.0,
      "text": "Sommige schepen vertrekken.\nSommige verdwijnen in de geschiedenis.\nSommige doen beide."
    },
    {
      "id": "pause_wind",
      "type": "atmospheric",
      "start": 7.0,
      "end": 9.0,
      "description": "Lange pauze. Alleen wind."
    },
    {
      "id": "block_2_three",
      "type": "narration",
      "start": 9.0,
      "end": 14.5,
      "text": "Sindsdien zijn er drie vertrokken.\nHonderd jaar uit elkaar.\nNaar hetzelfde wit."
    },
    {
      "id": "transition_mast",
      "type": "atmospheric",
      "start": 14.5,
      "end": 15.5,
      "description": "Camera onder de mast door."
    },
    {
      "id": "block_3_motives",
      "type": "narration",
      "start": 15.5,
      "end": 22.0,
      "text": "De een ging om te overleven.\nDe ander om een spoor achter te laten.\nDe derde om de wind te volgen."
    },
    {
      "id": "transition_door",
      "type": "atmospheric",
      "start": 22.0,
      "end": 23.5,
      "description": "Houten deur. Een hand. Een aarzeling."
    },
    {
      "id": "block_4_call",
      "type": "narration",
      "start": 23.5,
      "end": 27.5,
      "text": "Ze hoorden allemaal dezelfde roep —\nde roep van het zesde continent."
    },
    {
      "id": "transition_door_opens",
      "type": "atmospheric",
      "start": 27.5,
      "end": 28.5,
      "description": "Deur opent. We zijn in de cabine."
    },
    {
      "id": "block_5_now",
      "type": "narration",
      "start": 28.5,
      "end": 30.5,
      "text": "Nu hoor jij hem ook."
    },
    {
      "id": "final_silence",
      "type": "atmospheric",
      "start": 30.5,
      "end": 32.5,
      "description": "Stilte. Drie kapiteinskaarten verschijnen langzaam."
    },
    {
      "id": "block_6_invitation",
      "type": "narration",
      "start": 32.5,
      "end": 35.0,
      "text": "Welke ga je beantwoorden?"
    }
  ]
}
